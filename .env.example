# Clerk authentication — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostgreSQL — Neon connection pooler URL
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Trigger.dev — https://cloud.trigger.dev (DEV environment secret)
TRIGGER_SECRET_KEY=tr_dev_...

# Google Generative AI — https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AI...

# Transloadit — https://transloadit.com/c/template-credentials/
TRANSLOADIT_KEY=
TRANSLOADIT_SECRET=

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Build attribution (logged on every page render)
NEXT_PUBLIC_CANDIDATE_LINKEDIN=https://www.linkedin.com/in/your-handle
